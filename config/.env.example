# ============================================================
# La RST — Exemple de configuration environnement (.env)
# Version : 1.0.0
# ============================================================

# ------------------------------------------------------------
# API
# ------------------------------------------------------------
# Port d'exécution du backend
API_PORT=3000

# Token d'administration (auth simple v1.0.0)
# À remplacer par une valeur forte en production
ADMIN_TOKEN=changeme_admin_token


# ------------------------------------------------------------
# Base de données PostgreSQL
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=larst_user
DB_PASSWORD=changeme_password
DB_NAME=larst_db


# ------------------------------------------------------------
# Options diverses
# ------------------------------------------------------------
# Niveau de logs : debug | info | warn | error
LOG_LEVEL=info

# Origine autorisée pour le frontend
CORS_ORIGIN=http://localhost:8080
